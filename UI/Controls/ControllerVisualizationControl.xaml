<UserControl
    x:Class="Dali.UI.Controls.ControllerVisualizationControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:Dali.UI.ViewModels"
    d:DesignHeight="600"
    d:DesignWidth="480"
    mc:Ignorable="d">

    <Grid>
        <Border
            Background="{DynamicResource SecondaryBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1,0,0,0">

            <ScrollViewer
                HorizontalScrollBarVisibility="Disabled"
                VerticalScrollBarVisibility="Auto">

                <StackPanel Margin="10,10,10,16">

                    <!-- ====== Controller card ====== -->
                    <Border
                        Margin="0,0,0,0"
                        Padding="12,10"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6">
                        <StackPanel>
                            <TextBlock
                                FontSize="11"
                                Foreground="#888888"
                                Text="{Binding PanelName}" />
                            <TextBlock
                                FontSize="20"
                                FontWeight="Bold"
                                Foreground="{DynamicResource ForegroundBrush}"
                                Text="{Binding ControllerName}"
                                TextTrimming="CharacterEllipsis" />
                            <TextBlock
                                FontSize="11"
                                Foreground="#777777"
                                Text="{Binding DeviceModel}" />
                        </StackPanel>
                    </Border>

                    <!-- ====== Output columns (wrapping, no horizontal scroll) ====== -->
                    <ItemsControl ItemsSource="{Binding Outputs}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Margin" Value="0,0,10,10" />
                            </Style>
                        </ItemsControl.ItemContainerStyle>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:ControllerOutputVizVm}">

                                <!-- One output column: 116 px wide -->
                                <Grid Width="116">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />  <!-- Line name box -->
                                        <RowDefinition Height="*" />     <!-- device group nodes -->
                                    </Grid.RowDefinitions>

                                    <!-- Full-height stem behind everything; box background masks it -->
                                    <Rectangle
                                        Grid.RowSpan="2"
                                        Width="1"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Stretch"
                                        Fill="#555555" />
                                    <Border
                                        Grid.Row="0"
                                        Padding="6,5"
                                        HorizontalAlignment="Center"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="3"
                                        MinWidth="54">
                                        <TextBlock
                                            HorizontalAlignment="Center"
                                            FontSize="11"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource ForegroundBrush}"
                                            Text="{Binding BoxLabel}"
                                            TextTrimming="CharacterEllipsis" />
                                    </Border>

                                    <!-- Device group nodes -->
                                    <ItemsControl Grid.Row="1" ItemsSource="{Binding FirstLine.Groups}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type vm:DeviceGroupVizVm}">
                                                    <!--
                                                        Layout: [param value] [circle-X node] [count tk.]
                                                        Col widths: 46 + 24 + 46 = 116
                                                        The center column carries the vertical stem line.
                                                    -->
                                                    <Grid Height="44">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="46" />
                                                            <ColumnDefinition Width="24" />
                                                            <ColumnDefinition Width="46" />
                                                        </Grid.ColumnDefinitions>

                                                        <!-- Vertical stem (behind circle) -->
                                                        <Rectangle
                                                            Grid.Column="1"
                                                            Width="1"
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Stretch"
                                                            Fill="#555555" />

                                                        <!-- Schematic node: circle + X -->
                                                        <Grid
                                                            Grid.Column="1"
                                                            Width="22"
                                                            Height="22"
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center">
                                                            <!-- Background cuts the stem so the circle appears solid -->
                                                            <Ellipse Fill="{DynamicResource SecondaryBackgroundBrush}" />
                                                            <Ellipse Stroke="#AAAAAA" StrokeThickness="1.5" />
                                                            <Canvas Width="22" Height="22">
                                                                <Line X1="5" Y1="5" X2="17" Y2="17" Stroke="#AAAAAA" StrokeThickness="1.2" />
                                                                <Line X1="17" Y1="5" X2="5" Y2="17" Stroke="#AAAAAA" StrokeThickness="1.2" />
                                                            </Canvas>
                                                        </Grid>

                                                        <!-- Parameter value to the LEFT -->
                                                        <TextBlock
                                                            Grid.Column="0"
                                                            Margin="0,0,5,0"
                                                            HorizontalAlignment="Right"
                                                            VerticalAlignment="Center"
                                                            FontSize="11"
                                                            Foreground="{DynamicResource ForegroundBrush}"
                                                            Text="{Binding Key}"
                                                            TextTrimming="CharacterEllipsis"
                                                            ToolTip="{Binding Key}" />

                                                        <!-- Count to the RIGHT -->
                                                        <TextBlock
                                                            Grid.Column="2"
                                                            Margin="5,0,0,0"
                                                            HorizontalAlignment="Left"
                                                            VerticalAlignment="Center"
                                                            FontSize="11"
                                                            Foreground="#AAAAAA"
                                                            Text="{Binding CountLabel}" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                    <!-- Placeholder when output has no line assigned -->
                                    <TextBlock
                                        Grid.Row="1"
                                        HorizontalAlignment="Center"
                                        FontSize="10"
                                        FontStyle="Italic"
                                        Foreground="#444444"
                                        Text="&#x2014;">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding FirstLine}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
