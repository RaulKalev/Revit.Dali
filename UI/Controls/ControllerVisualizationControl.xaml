<UserControl
    x:Class="Dali.UI.Controls.ControllerVisualizationControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:Dali.UI.ViewModels"
    d:DesignHeight="600"
    d:DesignWidth="360"
    mc:Ignorable="d">

    <Grid>
        <Border
            Background="{DynamicResource SecondaryBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1,0,0,0">

            <!-- Main scrollable content -->
            <ScrollViewer
                HorizontalScrollBarVisibility="Disabled"
                VerticalScrollBarVisibility="Auto">

                <!-- ContentRoot hosts both the item stack and the connector canvas overlay -->
                <Grid x:Name="ContentRoot" SizeChanged="ContentRoot_SizeChanged">

                    <!-- === Content stack === -->
                    <StackPanel x:Name="ContentPanel" Margin="8,8,8,16">

                        <!-- Controller header card -->
                        <Border
                            Margin="0,0,0,10"
                            Padding="10,8"
                            Background="{DynamicResource PrimaryBackgroundBrush}"
                            BorderBrush="#70babc"
                            BorderThickness="0,0,0,2"
                            CornerRadius="4">
                            <StackPanel>
                                <TextBlock
                                    FontSize="15"
                                    FontWeight="Bold"
                                    Foreground="{DynamicResource ForegroundBrush}"
                                    Text="{Binding PanelName}" />
                                <TextBlock
                                    FontSize="12"
                                    Foreground="#CCCCCC"
                                    Text="{Binding ControllerName}" />
                                <StackPanel Margin="0,4,0,0" Orientation="Horizontal">
                                    <TextBlock
                                        FontSize="11"
                                        Foreground="#888888"
                                        Text="{Binding DeviceModel}" />
                                    <TextBlock
                                        Margin="8,0,0,0"
                                        FontSize="11"
                                        Foreground="#888888"
                                        Text="{Binding OutputCount, StringFormat='Outputs: {0}'}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Output rows -->
                        <ItemsControl x:Name="OutputsItemsControl" ItemsSource="{Binding Outputs}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:ControllerOutputVizVm}">
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="36" />   <!-- port column -->
                                            <ColumnDefinition Width="*" />    <!-- line cards column -->
                                        </Grid.ColumnDefinitions>

                                        <!-- Port circle (left) -->
                                        <Border
                                            x:Name="PortBorder"
                                            Grid.Column="0"
                                            Width="28"
                                            Height="28"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Top"
                                            Margin="0,6,0,0"
                                            Background="{DynamicResource PrimaryBackgroundBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="14"
                                            Tag="{Binding OutputNumber}"
                                            Loaded="OutputPort_Loaded"
                                            ToolTip="{Binding OutputNumber, StringFormat='Output {0}'}">
                                            <TextBlock
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                FontSize="11"
                                                FontWeight="Bold"
                                                Foreground="{DynamicResource ForegroundBrush}"
                                                Text="{Binding OutputNumber}" />
                                        </Border>

                                        <!-- Line cards (right) -->
                                        <ItemsControl Grid.Column="1" ItemsSource="{Binding Lines}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type vm:DaliLineVizVm}">
                                                    <Border
                                                        Margin="6,2,0,2"
                                                        Padding="8,6"
                                                        Background="{DynamicResource PrimaryBackgroundBrush}"
                                                        BorderBrush="{DynamicResource BorderBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="4"
                                                        Tag="{Binding LineName}"
                                                        Loaded="LineCard_Loaded">
                                                        <StackPanel>
                                                            <!-- Line header row -->
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="Auto" />
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock
                                                                    Grid.Column="0"
                                                                    FontSize="12"
                                                                    FontWeight="SemiBold"
                                                                    Foreground="{DynamicResource ForegroundBrush}"
                                                                    Text="{Binding LineName}"
                                                                    TextTrimming="CharacterEllipsis" />
                                                                <TextBlock
                                                                    Grid.Column="1"
                                                                    Margin="6,0,0,0"
                                                                    FontSize="11"
                                                                    Foreground="#888888"
                                                                    Text="{Binding DeviceCountDisplay}" />
                                                            </Grid>

                                                            <!-- Device groups (always shown, empty means no groups yet) -->
                                                            <ItemsControl
                                                                Margin="0,4,0,0"
                                                                ItemsSource="{Binding Groups}">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate DataType="{x:Type vm:DeviceGroupVizVm}">
                                                                        <TextBlock
                                                                            Margin="0,1"
                                                                            FontSize="11"
                                                                            Foreground="#AAAAAA"
                                                                            Text="{Binding DisplayText}" />
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!-- Empty output slot hint (no lines defined for this output) -->
                                        <TextBlock
                                            Grid.Column="1"
                                            Margin="10,9,0,0"
                                            FontSize="11"
                                            FontStyle="Italic"
                                            Foreground="#555555"
                                            Text="(no line assigned)">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Lines.Count}" Value="0">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                    </StackPanel>

                    <!-- Connector canvas overlay — same coordinate space as ContentRoot, no input capture -->
                    <Canvas
                        x:Name="ConnectorCanvas"
                        IsHitTestVisible="False"
                        ClipToBounds="False" />

                </Grid>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
