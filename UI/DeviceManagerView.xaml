<UserControl x:Class="Dali.UI.DeviceManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:ui="clr-namespace:Dali.UI"
             mc:Ignorable="d" 
             d:DesignHeight="500" d:DesignWidth="600"
             Background="{DynamicResource PrimaryBackgroundBrush}">

    <UserControl.Resources>
        <ui:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
        <ui:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <ui:NullToCollapsedConverter x:Key="NullToCollapsedConverter"/>
    </UserControl.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header -->
            <RowDefinition Height="*"/>    <!-- Main Content Split -->
        </Grid.RowDefinitions>
        
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Device Equipment Database" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource ForegroundBrush}"/>
            <Button Grid.Column="1" Command="{Binding AddNewDeviceCommand}" Background="Transparent" BorderBrush="Transparent" Foreground="LightGreen" ToolTip="Add New Custom Device">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="PlusCircleOutline" Width="18" Height="18" Margin="0,0,5,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Add Device" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- Main Split: Grid Left, Edit Right -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="4*"/> <!-- Device List -->
                <ColumnDefinition Width="10"/> <!-- Splitter -->
                <ColumnDefinition Width="5*"/> <!-- Edit Form -->
            </Grid.ColumnDefinitions>

            <!-- LEFT: Device DataGrid -->
            <Border Grid.Column="0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4">
                <DataGrid ItemsSource="{Binding Devices}"
                          SelectedItem="{Binding SelectedDevice}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          SelectionMode="Single"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#333333"
                          RowBackground="Transparent"
                          Background="Transparent"
                          BorderThickness="0"
                          Foreground="{DynamicResource ForegroundBrush}"
                          IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="Auto" CanUserSort="True"/>
                        <DataGridTextColumn Header="Model" Binding="{Binding Model}" Width="Auto" CanUserSort="True"/>
                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" CanUserSort="True"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Background="Transparent" />

            <!-- RIGHT: Edit Form -->
            <Border Grid.Column="2" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="15">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Edit Device Parameters" FontWeight="SemiBold" FontSize="14" Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,0,15"/>

                        <StackPanel Visibility="{Binding ActiveEditDevice, Converter={StaticResource NullToCollapsedConverter}}">
                            
                            <!-- ID (Read-only reference) -->
                            <TextBlock Text="Database ID" Foreground="Gray" Margin="0,0,0,2"/>
                            <TextBox Text="{Binding ActiveEditDevice.Id}" IsReadOnly="True" Style="{DynamicResource CustomTextBoxStyle}" Foreground="DarkGray" Background="#111" Margin="0,0,0,10"/>

                            <!-- General Info -->
                            <TextBlock Text="Equipment Type (e.g., controller, power_supply)" Foreground="Gray" Margin="0,0,0,2"/>
                            <TextBox Text="{Binding ActiveEditDevice.Type, UpdateSourceTrigger=PropertyChanged}" TextChanged="EditBox_TextChanged" Style="{DynamicResource CustomTextBoxStyle}" Margin="0,0,0,10"/>

                            <TextBlock Text="Model Designation" Foreground="Gray" Margin="0,0,0,2"/>
                            <TextBox Text="{Binding ActiveEditDevice.Model, UpdateSourceTrigger=PropertyChanged}" TextChanged="EditBox_TextChanged" Style="{DynamicResource CustomTextBoxStyle}" Margin="0,0,0,10"/>

                            <TextBlock Text="Display Name" Foreground="Gray" Margin="0,0,0,2"/>
                            <TextBox Text="{Binding ActiveEditDevice.Name, UpdateSourceTrigger=PropertyChanged}" TextChanged="EditBox_TextChanged" Style="{DynamicResource CustomTextBoxStyle}" Margin="0,0,0,15"/>

                            <!-- Divider -->
                            <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,5,0,15"/>

                            <!-- Controller specific capacities -->
                            <StackPanel Visibility="{Binding IsController, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Text="Controller Port Capacities" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,0,10"/>

                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="DALI Lines Supported" Foreground="Gray" Margin="0,0,0,2"/>
                                        <TextBox Text="{Binding ActiveEditDevice.DaliLines, UpdateSourceTrigger=PropertyChanged}" TextChanged="EditBox_TextChanged" Style="{DynamicResource CustomTextBoxStyle}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Max Addresses Per Line" Foreground="Gray" Margin="0,0,0,2"/>
                                        <TextBox Text="{Binding ActiveEditDevice.MaxAddressesPerLine, UpdateSourceTrigger=PropertyChanged}" TextChanged="EditBox_TextChanged" Style="{DynamicResource CustomTextBoxStyle}"/>
                                    </StackPanel>
                                </Grid>

                                <Grid Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Rated Output (mA)" Foreground="Gray" Margin="0,0,0,2"/>
                                        <TextBox Text="{Binding ActiveEditDevice.RatedCurrentmAPerLine, UpdateSourceTrigger=PropertyChanged}" TextChanged="EditBox_TextChanged" Style="{DynamicResource CustomTextBoxStyle}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Guaranteed Output (mA)" Foreground="Gray" Margin="0,0,0,2"/>
                                        <TextBox Text="{Binding ActiveEditDevice.GuaranteedCurrentmAPerLine, UpdateSourceTrigger=PropertyChanged}" TextChanged="EditBox_TextChanged" Style="{DynamicResource CustomTextBoxStyle}"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>

                            <!-- Extender specific capacities (Future proofing) -->
                            <StackPanel Visibility="{Binding IsController, Converter={StaticResource InverseBooleanConverter}}">
                                <TextBlock Text="Power / Extender Additions" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,0,10"/>
                                <Grid Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Adds Current (mA)" Foreground="Gray" Margin="0,0,0,2"/>
                                        <TextBox Text="{Binding ActiveEditDevice.AddsCurrentmA, UpdateSourceTrigger=PropertyChanged}" TextChanged="EditBox_TextChanged" Style="{DynamicResource CustomTextBoxStyle}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Extends Length (Meters)" Foreground="Gray" Margin="0,0,0,2"/>
                                        <TextBox Text="{Binding ActiveEditDevice.ExtendsLineLengthMetersTo, UpdateSourceTrigger=PropertyChanged}" TextChanged="EditBox_TextChanged" Style="{DynamicResource CustomTextBoxStyle}"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>

                            <!-- Actions -->
                            <Grid Margin="0,20,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Delete -->
                                <Button Grid.Column="0" Command="{Binding DeleteDeviceCommand}" CommandParameter="{Binding ActiveEditDevice}" HorizontalAlignment="Left" Background="Transparent" BorderBrush="Transparent" Foreground="LightCoral" ToolTip="Delete this device">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="TrashCanOutline" Width="16" Height="16" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Delete" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <!-- Save -->
                                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <TextBlock Text="* Unsaved Changes" Foreground="Gold" FontStyle="Italic" VerticalAlignment="Center" Margin="0,0,10,0"
                                               Visibility="{Binding HasChanges, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    <Button Content="Save Changes" Command="{Binding SaveDeviceCommand}" Style="{DynamicResource CustomActionButtonStyle}" Height="35" Width="120" FontSize="13" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>

                        <!-- Fallback empty state -->
                        <TextBlock Text="Select a device from the list to view or edit its parameters." 
                                   Foreground="Gray" FontStyle="Italic" TextWrapping="Wrap"
                                   Visibility="{Binding ActiveEditDevice, Converter={StaticResource InverseBooleanConverter}, FallbackValue=Visible}"/>

                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>
